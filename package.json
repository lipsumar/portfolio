{
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate.js",
    "dev": "node scripts/generate.js && concurrently \"node scripts/generate.js --watch\" \"parcel index.html\"",
    "build": "node scripts/generate.js && parcel build index.html --dist-dir dist",
    "thumbs": "sh scripts/thumbs.sh",
    "jpg2png": "sh scripts/jpg2png.sh",
    "img-optimize": "pngquant --force --ext .png projects/**/*.png"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^9.2.1",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.4",
    "parcel": "^2.16.4",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0"
  },
  "packageManager": "yarn@4.15.0"
}
